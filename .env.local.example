# Trophē v0.3 — local development env
# Copy to .env.local and fill in. NEVER commit .env.local.
#
# Production env (Vercel) keeps NEXT_PUBLIC_SUPABASE_* + SUPABASE_SERVICE_ROLE_KEY
# pointing at production Supabase. DATABASE_URL is local-only until Phase 9 cutover.

# ─── Database (Mac Mini open_brain_postgres) ──────────────────────────────
# 127.0.0.1 NOT localhost — macOS resolves localhost to ::1 first; container
# only binds IPv4. Phase 0 discovery.
DATABASE_URL=postgresql://brain_user:CHANGEME@127.0.0.1:5433/trophe_dev

# ─── Supabase (auth still hosted; data via DATABASE_URL above) ────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── LLM keys (shared with Mac Mini control plane) ────────────────────────
# Source from ~/.local/secrets/{anthropic,providers,voyage}.env when running
# locally. Production uses Vercel env vars.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AI...
VOYAGE_API_KEY=pa-...

# ─── Langfuse (Mac Mini @ localhost:3002 for local dev) ───────────────────
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=http://127.0.0.1:3002

# ─── USDA FoodData Central (optional — falls back to DEMO_KEY) ───────────
USDA_API_KEY=your-usda-key

# ─── Phase 6 (Spike peripherals — only when needed) ───────────────────────
SPIKE_API_KEY=
SPIKE_WEBHOOK_SECRET=

# ─── Admin (legacy; replaced by role enum in Phase 1) ─────────────────────
TROPHE_ADMIN_EMAILS=daniel@reyes.com
