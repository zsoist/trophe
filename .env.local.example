# Trophē — Required Environment Variables

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI APIs (required for food parse + photo analyze + meal suggestions)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...

# USDA FoodData Central (optional — falls back to DEMO_KEY with rate limits)
USDA_API_KEY=your-usda-key

# Admin access (optional — defaults to daniel@reyes.com)
TROPHE_ADMIN_EMAILS=daniel@reyes.com
