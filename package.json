    "@tanstack/react-query": "^5.100.7",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@vercel/analytics": "^2.0.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "langfuse": "^3.38.20",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "pg": "^8.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "supabase": "^2.98.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
